generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  metrics   Metric[]
  users     User[]
}

model User {
  id       String       @id @default(uuid())
  email    String       @unique
  password String
  role     Role
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id])
}

model Metric {
  id        String       @id @default(uuid())
  orgId     String
  date      DateTime
  revenue   Float
  orders    Int
  customers Int
  org       Organization @relation(fields: [orgId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  action    String
  metadata  String?
  createdAt DateTime @default(now())
}
